<launch>
  <arg name="uav_ns" default="target_0"/>

  <arg name="map_size_x" default="40.0"/>
  <arg name="map_size_y" default="40.0"/>
  <arg name="map_size_z" default="3.0"/>

  <arg name="odom_topic" default="/$(arg uav_ns)/odom"/>
  <arg name="waypoints_topic" default="/$(arg uav_ns)/waypoint_generator/waypoints"/>

    <group ns="$(arg uav_ns)">

  <!-- 把 ego-planner 官方写死的根命名空间输出收回到 /target_0 下 -->
    <remap from="/planning/bspline" to="/$(arg uav_ns)/planning/bspline"/>
    <remap from="/planning/data_display" to="/$(arg uav_ns)/planning/data_display"/>
    <remap from="/grid_map/occupancy" to="/$(arg uav_ns)/grid_map/occupancy"/>
    <remap from="/grid_map/occupancy_inflate" to="/$(arg uav_ns)/grid_map/occupancy_inflate"/>
    <remap from="/grid_map/unknown" to="/$(arg uav_ns)/grid_map/unknown"/>

  <include file="$(find ego_planner)/launch/advanced_param.xml">
      <arg name="map_size_x_" value="$(arg map_size_x)"/>
      <arg name="map_size_y_" value="$(arg map_size_y)"/>
      <arg name="map_size_z_" value="$(arg map_size_z)"/>

      <arg name="odometry_topic" value="$(arg odom_topic)"/>

      <arg name="camera_pose_topic" value="/$(arg uav_ns)/unused_camera_pose"/>
      <arg name="depth_topic" value="/$(arg uav_ns)/unused_depth"/>
      <arg name="cloud_topic" value="/$(arg uav_ns)/mock_map"/>

      <arg name="cx" value="321.04638671875"/>
      <arg name="cy" value="243.44969177246094"/>
      <arg name="fx" value="387.229248046875"/>
      <arg name="fy" value="387.229248046875"/>

      <arg name="max_vel" value="2.0"/>
      <arg name="max_acc" value="3.0"/>
      <arg name="planning_horizon" value="7.5"/>

      <arg name="flight_type" value="2"/>

      <arg name="point_num" value="1"/>

      <arg name="point0_x" value="20.0"/>
      <arg name="point0_y" value="0.0"/>
      <arg name="point0_z" value="2.0"/>

      <arg name="point1_x" value="20.0"/>
      <arg name="point1_y" value="0.0"/>
      <arg name="point1_z" value="2.0"/>

      <arg name="point2_x" value="20.0"/>
      <arg name="point2_y" value="0.0"/>
      <arg name="point2_z" value="2.0"/>

      <arg name="point3_x" value="20.0"/>
      <arg name="point3_y" value="0.0"/>
      <arg name="point3_z" value="2.0"/>

      <arg name="point4_x" value="20.0"/>
      <arg name="point4_y" value="0.0"/>
      <arg name="point4_z" value="2.0"/>
    </include>

  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="/$(arg uav_ns)/planning/pos_cmd"/>
    <remap from="/odom_world" to="/$(arg uav_ns)/odom"/>
    <param name="traj_server/time_forward" value="1.0" type="double"/>
  </node>

</group>
   
</launch>